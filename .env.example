# Set both of these in Vercel → Project → Settings → Environment Variables
# (Production + Preview). Locally, copy this file to .env.local and fill in.

# Supabase Postgres connection string (use the pooled URL on port 6543).
POSTGRES_URL=postgres://USER:PASSWORD@HOST:6543/postgres?sslmode=require

# Single shared password for the /admin console. Pick something memorable.
ADMIN_PASSWORD=change-me
